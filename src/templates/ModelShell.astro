---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/nav/Breadcrumbs.astro';
import ModelSubNav from '../components/nav/ModelSubNav.astro';
import SourcesFooter from '../components/data/SourcesFooter.astro';
import VerifiedBadge from '../components/data/VerifiedBadge.astro';
import { modelSources, oldestVerified } from '../lib/sources';
import { breadcrumbs as breadcrumbsLd } from '../lib/jsonld';

interface Props {
  model: CollectionEntry<'models'>;
  vendor: CollectionEntry<'vendors'>;
  title: string;
  description: string;
  /** Active sub-nav tab key ('hub', 'pricing', ...). */
  active: string;
  /** Sub-page keys that exist for this model. */
  available: string[];
  /** Visible h1; defaults to the model name. */
  heading?: string;
  /** Crumb for the current page when not the hub. */
  crumbLabel?: string;
  extraJsonld?: object[];
}

const { model, vendor, title, description, active, available, heading, crumbLabel, extraJsonld = [] } = Astro.props;
const sources = modelSources(model);
const slug = model.data.slug;

const crumbs = [
  { label: 'Models', href: '/models' },
  ...(active === 'hub'
    ? [{ label: model.data.name }]
    : [{ label: model.data.name, href: `/${slug}` }, { label: crumbLabel ?? active }]),
];
const crumbsLd = breadcrumbsLd([
  { name: 'Models', path: '/models' },
  ...(active === 'hub'
    ? [{ name: model.data.name }]
    : [{ name: model.data.name, path: `/${slug}` }, { name: crumbLabel ?? active }]),
]);

const tierLabel: Record<string, string> = {
  flagship: 'Flagship',
  reasoning: 'Reasoning',
  mid: 'Mid-tier',
  small: 'Small',
  coding: 'Coding',
  open: 'Open weights',
};
---

<BaseLayout title={title} description={description} jsonld={[crumbsLd, ...extraJsonld]}>
  <Breadcrumbs items={crumbs} />

  <header>
    <div class="flex flex-wrap items-center gap-x-3 gap-y-2">
      <h1 class="text-2xl font-semibold tracking-tight sm:text-3xl">{heading ?? model.data.name}</h1>
      <span class="rounded-full border border-line px-2.5 py-0.5 text-[11px] font-medium text-ink-2">
        {tierLabel[model.data.tier]}
      </span>
      {
        model.data.status !== 'current' && (
          <span class="rounded-full border border-line px-2.5 py-0.5 text-[11px] font-medium text-bad capitalize">
            {model.data.status}
          </span>
        )
      }
    </div>
    <div class="mt-2 flex flex-wrap items-center gap-3 text-[13px] text-ink-2">
      <span>
        by <a href={vendor.data.url} rel="noopener" class="font-medium underline decoration-line underline-offset-2 hover:text-ink">{vendor.data.name}</a>
      </span>
      <VerifiedBadge date={oldestVerified(model)} />
    </div>
  </header>

  <ModelSubNav model={model} active={active} available={available} />

  <div class="py-8">
    <slot />
  </div>

  <SourcesFooter sources={sources.list} />
</BaseLayout>
