---
import { getCollection, getEntry } from 'astro:content';
import type { FlatPage } from '../lib/routes';
import ModelShell from './ModelShell.astro';

interface Props {
  page: Extract<FlatPage, { type: 'model-prompts' }>;
  available: string[];
}

const { page, available } = Astro.props;
const model = page.model;
const d = model.data;
const vendor = (await getEntry(d.vendor))!;
const prompts = (await getCollection('prompts')).filter((p) => p.data.models.some((r) => r.id === model.id));
---

<ModelShell
  model={model}
  vendor={vendor}
  title={page.title}
  description={page.description}
  active="prompts"
  available={available}
  heading={`Prompts for ${d.name}`}
  crumbLabel="Prompts"
>
  <p class="prose-site" data-pagefind-body>
    Prompts from our library tested with {d.name}, grouped by task.
  </p>

  <div class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-2">
    {
      prompts.map((p) => (
        <a href={`/prompts/${p.data.slug}`} class="group border border-line p-4 transition-colors hover:border-line-strong">
          <div class="text-[11px] font-semibold tracking-wider text-ink-3 uppercase">{p.data.category}</div>
          <div class="mt-1 text-[14px] font-semibold group-hover:text-accent-text">{p.data.title}</div>
          <p class="mt-1 text-[13px] leading-relaxed text-ink-2">{p.data.description}</p>
        </a>
      ))
    }
  </div>
</ModelShell>
