---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/nav/Breadcrumbs.astro';
import { orderPair } from '../../lib/routes';
import { breadcrumbs } from '../../lib/jsonld';

const comparisons = await getCollection('comparisons');
const models = await getCollection('models');
const byId = new Map(models.map((m) => [m.id, m]));

const entries = comparisons
  .map((c) => {
    const a = byId.get(c.data.a.id)!;
    const b = byId.get(c.data.b.id)!;
    const [first, second] = orderPair(a, b);
    return { first, second, hasVerdict: Boolean(c.data.verdict) };
  })
  .sort((x, y) => x.first.data.priority - y.first.data.priority || x.second.data.priority - y.second.data.priority);

const groups = [
  { label: 'Flagship matchups', filter: (e: (typeof entries)[number]) => e.first.data.tier === 'flagship' && e.second.data.tier === 'flagship' },
  { label: 'Mid-tier matchups', filter: (e: (typeof entries)[number]) => e.first.data.tier === 'mid' || e.second.data.tier === 'mid' },
  { label: 'Fast & small models', filter: (e: (typeof entries)[number]) => e.first.data.tier === 'small' || e.second.data.tier === 'small' },
];
const used = new Set<(typeof entries)[number]>();
---

<BaseLayout
  title="AI Model Comparisons: Head-to-Head Specs & Benchmarks"
  description="Side-by-side comparisons of every major AI model pairing (GPT-5.6 vs Claude, Gemini vs Grok, DeepSeek vs Mistral), with benchmarks, pricing, and context windows from official sources."
  jsonld={[breadcrumbs([{ name: 'Comparisons' }])]}
>
  <Breadcrumbs items={[{ label: 'Comparisons' }]} />

  <h1 class="text-2xl font-semibold tracking-tight sm:text-3xl">Model Comparisons</h1>
  <p class="mt-2 max-w-2xl text-[14px] leading-relaxed text-ink-2" data-pagefind-body>
    {entries.length} head-to-head matchups with spec-by-spec grids, benchmark deltas, and a written verdict for the
    big rivalries. Marked ★ where a verdict is included.
  </p>

  <form id="compare-picker" class="mt-6 flex max-w-2xl flex-wrap items-end gap-3 border border-line bg-surface-2 p-4">
    <label class="min-w-40 flex-1">
      <span class="text-[11px] font-semibold tracking-wider text-ink-3 uppercase">Model A</span>
      <select id="pick-a" class="mt-1.5 w-full border border-line-strong bg-surface px-3 py-2 text-[13px]">
        {models.sort((a, b) => a.data.priority - b.data.priority).map((m) => <option value={m.data.slug}>{m.data.name}</option>)}
      </select>
    </label>
    <label class="min-w-40 flex-1">
      <span class="text-[11px] font-semibold tracking-wider text-ink-3 uppercase">Model B</span>
      <select id="pick-b" class="mt-1.5 w-full border border-line-strong bg-surface px-3 py-2 text-[13px]">
        {models.map((m) => <option value={m.data.slug} selected={m.data.priority === 2}>{m.data.name}</option>)}
      </select>
    </label>
    <button
      type="submit"
      id="pick-go"
      class="border border-accent bg-accent px-4 py-2 text-[13px] font-semibold text-white transition-opacity disabled:cursor-not-allowed disabled:opacity-40"
    >
      Compare
    </button>
    <p id="pick-note" class="w-full text-[12px] text-ink-3"></p>
  </form>

  <script
    is:inline
    define:vars={{
      pairs: entries.map((e) => `${e.first.data.slug}-vs-${e.second.data.slug}`),
    }}
  >
    const valid = new Set(pairs);
    const a = document.getElementById('pick-a');
    const b = document.getElementById('pick-b');
    const go = document.getElementById('pick-go');
    const note = document.getElementById('pick-note');
    const urlFor = () => {
      const forward = `${a.value}-vs-${b.value}`;
      const reverse = `${b.value}-vs-${a.value}`;
      return valid.has(forward) ? `/${forward}` : valid.has(reverse) ? `/${reverse}` : null;
    };
    const refresh = () => {
      const url = urlFor();
      go.disabled = !url;
      note.textContent = url ? '' : a.value === b.value ? 'Pick two different models.' : "We haven't built this matchup yet.";
    };
    a.addEventListener('change', refresh);
    b.addEventListener('change', refresh);
    document.getElementById('compare-picker').addEventListener('submit', (e) => {
      e.preventDefault();
      const url = urlFor();
      if (url) location.href = url;
    });
    refresh();
  </script>

  {
    groups.map((group) => {
      const groupEntries = entries.filter((e) => !used.has(e) && group.filter(e));
      groupEntries.forEach((e) => used.add(e));
      if (groupEntries.length === 0) return null;
      return (
        <section class="mt-10">
          <h2 class="text-lg font-semibold tracking-tight">{group.label}</h2>
          <ul class="mt-4 grid grid-cols-1 gap-2 sm:grid-cols-2">
            {groupEntries.map((e) => (
              <li>
                <a
                  href={`/${e.first.data.slug}-vs-${e.second.data.slug}`}
                  class="group flex items-baseline justify-between gap-2 border border-line px-4 py-3 transition-colors hover:border-line-strong"
                >
                  <span class="text-[14px] font-medium group-hover:text-accent-text">
                    {e.first.data.name} <span class="text-ink-3">vs</span> {e.second.data.name}
                  </span>
                  {e.hasVerdict && <span class="text-[12px] text-accent-text" title="Includes written verdict">★</span>}
                </a>
              </li>
            ))}
          </ul>
        </section>
      );
    })
  }
</BaseLayout>
