---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SECTIONS } from '../data/site';

const popular = SECTIONS.filter((s) => ['models', 'comparisons', 'pricing'].includes(s.slug));
---

<BaseLayout title="Page not found — AIStudio" description="This page doesn't exist." noindex>
  <section class="py-24">
    <p class="num text-[13px] text-ink-3">404</p>
    <h1 class="mt-2 text-3xl font-semibold tracking-tight">Page not found</h1>
    <p class="mt-3 max-w-md text-[14px] leading-relaxed text-ink-2">
      The page you're looking for doesn't exist — it may have moved when a model was renamed or retired.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/" class="border border-line-strong px-4 py-2 text-[13px] font-medium transition-colors hover:border-accent hover:text-accent-text">
        Go home
      </a>
      {
        popular.map((s) => (
          <a href={`/${s.slug}`} class="border border-line px-4 py-2 text-[13px] text-ink-2 transition-colors hover:border-line-strong hover:text-ink">
            {s.title}
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
