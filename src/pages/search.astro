---
import BaseLayout from '../layouts/BaseLayout.astro';
import Search from 'astro-pagefind/components/Search.astro';
---

<BaseLayout title="Search | AIStudio" description="Search every model, comparison, benchmark, and app on AIStudio." noindex>
  <div class="mx-auto max-w-2xl py-10">
    <h1 class="text-2xl font-semibold tracking-tight">Search</h1>
    <p class="mt-2 text-[14px] text-ink-2">Every model, spec page, comparison, benchmark, and app.</p>
    <div class="mt-6">
      <Search id="search" className="pagefind-ui" uiOptions={{ showImages: false, autofocus: true }} />
    </div>
  </div>
</BaseLayout>

<style is:global>
  .pagefind-ui {
    --pagefind-ui-primary: var(--accent-text);
    --pagefind-ui-text: var(--ink);
    --pagefind-ui-background: var(--surface);
    --pagefind-ui-border: var(--line-strong);
    --pagefind-ui-tag: var(--surface-2);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-font: inherit;
  }
</style>
