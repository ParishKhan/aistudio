---
interface Props {
  label: string;
  /** Rendered numeric display, e.g. "89.4%". */
  display: string;
  /** 0–1 fraction of the bar to fill. */
  fraction: number;
  /** Highlight this row (e.g. the page's own model in a ranking). */
  highlight?: boolean;
  href?: string;
}

const { label, display, fraction, highlight = false, href } = Astro.props;
const width = `${Math.max(0, Math.min(1, fraction)) * 100}%`;
---

<div class="flex items-center gap-3 py-1">
  <div class="w-36 shrink-0 truncate text-[13px] sm:w-44" class:list={[highlight ? 'font-semibold text-ink' : 'text-ink-2']}>
    {href ? <a href={href} class="transition-colors hover:text-accent-text">{label}</a> : label}
  </div>
  <div class="h-4 flex-1 bg-surface-2">
    <div class:list={['h-full', highlight ? 'bg-accent' : 'bg-line-strong']} style={`width: ${width}`}></div>
  </div>
  <div class="num w-16 shrink-0 text-right text-[13px]" class:list={[highlight && 'font-semibold']}>{display}</div>
</div>
