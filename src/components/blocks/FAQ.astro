---
export interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  items: FAQItem[];
  heading?: string;
}

const { items, heading = 'Frequently asked questions' } = Astro.props;
---

{
  items.length > 0 && (
    <section>
      <h2 class="text-lg font-semibold tracking-tight">{heading}</h2>
      <dl class="mt-4 divide-y divide-line border-y border-line">
        {items.map((item) => (
          <div class="py-4">
            <dt class="text-[14px] font-semibold">{item.q}</dt>
            <dd class="mt-1.5 max-w-2xl text-[14px] leading-relaxed text-ink-2">{item.a}</dd>
          </div>
        ))}
      </dl>
    </section>
  )
}
