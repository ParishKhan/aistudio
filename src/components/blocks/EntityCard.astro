---
interface Props {
  name: string;
  href: string;
  /** One-line descriptor under the name, e.g. vendor + tier. */
  meta: string;
  /** Up to ~3 key stats shown as label→value pairs. */
  stats?: { label: string; value: string }[];
}

const { name, href, meta, stats = [] } = Astro.props;
---

<a
  href={href}
  class="group block border border-line bg-surface p-4 transition-colors hover:border-line-strong"
>
  <div class="flex items-baseline justify-between gap-2">
    <span class="text-[15px] font-semibold tracking-tight group-hover:text-accent-text">{name}</span>
  </div>
  <div class="mt-0.5 text-[12px] text-ink-3">{meta}</div>
  {
    stats.length > 0 && (
      <dl class="mt-3 space-y-1 border-t border-line pt-3">
        {stats.map((s) => (
          <div class="flex items-baseline justify-between gap-2">
            <dt class="text-[12px] text-ink-3">{s.label}</dt>
            <dd class="num text-[12px] text-ink-2">{s.value}</dd>
          </div>
        ))}
      </dl>
    )
  }
</a>
