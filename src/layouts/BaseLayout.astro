---
import '../styles/global.css';
import Header from '../components/nav/Header.astro';
import Footer from '../components/nav/Footer.astro';
import SEO, { type SEOProps } from '../components/seo/SEO.astro';

type Props = SEOProps;

const seoProps = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEO {...seoProps} />
    <script is:inline>
      // Pre-paint theme resolution: no flash, no CLS.
      (() => {
        const stored = localStorage.getItem('theme');
        const dark = stored ? stored === 'dark' : matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.classList.toggle('dark', dark);
      })();
    </script>
    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col bg-surface text-ink">
    <Header />
    <main class="mx-auto w-full max-w-[1200px] flex-1 px-4 sm:px-6">
      <slot />
    </main>
    <Footer />
  </body>
</html>
